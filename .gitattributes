# Normalize line endings on checkin; auto-convert to native on checkout.
* text=auto eol=lf

# Binary types — never touch
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.gz binary
*.dmg binary
*.exe binary
*.node binary

# Generated assets — exclude from GitHub language stats
electron/api/extensions/bridge/* linguist-generated=true
